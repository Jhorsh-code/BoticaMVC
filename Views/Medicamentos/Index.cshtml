@model IEnumerable<BoticaMVC.Models.Medicamento>

@{
    ViewData["Title"] = "Medicamentos";

    var q = ViewBag.Q as string ?? "";
    var orden = ViewBag.Orden as string ?? "nombre";
    var soloActivos = ViewBag.SoloActivos is bool b ? b : true;

    var hoy = DateTime.Today;
    var limite30 = hoy.AddDays(30);
}

<div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
    <div>
        <h1 class="h3 mb-0">Medicamentos</h1>
        <div class="text-muted">Gestión del inventario (búsqueda, orden y acciones)</div>
    </div>

    <div class="d-flex gap-2 flex-wrap">
        <a class="btn app-btn app-btn-success" asp-action="Create">Nuevo</a>
        <a class="btn app-btn app-btn-outline" asp-action="Reporte">Reporte (Imprimir)</a>
        <a class="btn app-btn app-btn-outline" asp-action="ReporteExcel">Excel</a>
        <a class="btn app-btn app-btn-outline" asp-action="ReportePdf">PDF</a>
    </div>
</div>

@if (TempData["ok"] is string okMsg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @okMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
    </div>
}

<form method="get" class="row g-2 align-items-end mb-3">
    <div class="col-12 col-md-6 col-lg-4">
        <label class="form-label">Buscar</label>
        <input name="q" value="@q" class="form-control" placeholder="Nombre / Código / Lote / Laboratorio" />
    </div>

    <div class="col-12 col-md-3 col-lg-2">
        <label class="form-label">Orden</label>
        <select name="orden" class="form-select">
            <option value="nombre" selected="@(orden == "nombre")">Nombre</option>
            <option value="codigo" selected="@(orden == "codigo")">Código</option>
            <option value="stock" selected="@(orden == "stock")">Stock</option>
            <option value="vence" selected="@(orden == "vence")">Vencimiento</option>
        </select>
    </div>

    <div class="col-12 col-md-3 col-lg-2">
        <input type="hidden" name="soloActivos" value="false" />
        <div class="form-check mt-4">
            <input class="form-check-input" type="checkbox" id="soloActivos" name="soloActivos" value="true" @(soloActivos ? "checked" : "") />
            <label class="form-check-label" for="soloActivos">Solo activos</label>
        </div>
    </div>

    <div class="col-12 col-md-6 col-lg-2 d-grid">
        <button type="submit" class="btn app-btn app-btn-primary">Aplicar</button>
    </div>

    <div class="col-12 col-md-6 col-lg-2 d-grid">
        <a class="btn app-btn app-btn-outline" asp-action="Index">Limpiar</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Código</th>
                <th>Nombre</th>
                <th>Laboratorio</th>
                <th>Vence</th>
                <th class="text-end">Stock</th>
                <th class="text-end">Min</th>
                <th class="text-end">Venta</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>

        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var m in Model)
                {
                    var stockBajo = m.Stock <= m.StockMinimo;
                    var vencido = m.FechaVencimiento < hoy;
                    var porVencer = !vencido && m.FechaVencimiento <= limite30;

                    var badgeStock = stockBajo ? "bg-warning text-dark" : "bg-success";
                    var badgeVence = vencido ? "bg-danger" : (porVencer ? "bg-warning text-dark" : "bg-success");

                    <tr>
                        <td class="fw-semibold">@m.Codigo</td>
                        <td>@m.Nombre</td>
                        <td>@m.Laboratorio</td>
                        <td>
                            <span class="badge @badgeVence">
                                @m.FechaVencimiento.ToString("dd/MM/yyyy")
                            </span>
                        </td>
                        <td class="text-end">
                            <span class="badge @badgeStock">@m.Stock</span>
                        </td>
                        <td class="text-end">@m.StockMinimo</td>
                        <td class="text-end">@m.PrecioVenta.ToString("0.00")</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@m.Id">Ver</a>
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@m.Id">Editar</a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@m.Id">Eliminar</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center text-muted py-4">
                        No se encontraron medicamentos con los filtros actuales.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
