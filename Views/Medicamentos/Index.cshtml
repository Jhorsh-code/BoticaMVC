@model BoticaMVC.ViewModels.MedicamentosIndexVM

@{
    ViewData["Title"] = "Medicamentos";

    var q = ViewBag.Q as string ?? "";
    var orden = ViewBag.Orden as string ?? "codigo";
    var soloActivos = ViewBag.SoloActivos is bool b ? b : true;

    var hoy = DateTime.Today;
    var limite30 = hoy.AddDays(30);
}

<h2 class="mb-3">Medicamentos</h2>
<p class="text-muted mb-4">Gestión del inventario de medicamentos</p>

@if (TempData["ok"] is string okMsg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @okMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
    </div>
}

<div class="d-flex gap-2 flex-wrap mb-3">
    <a class="btn btn-success" asp-action="Create">+ Nuevo</a>
    <a class="btn btn-outline-dark" asp-action="Reporte">Reporte</a>
    <a class="btn btn-outline-success" asp-action="ReporteExcel">Excel</a>
    <a class="btn btn-outline-danger" asp-action="ReportePdf">PDF</a>
</div>

<form method="get" asp-action="Index" class="row g-2 align-items-end mb-3">
    <div class="col-12 col-md-6 col-lg-4">
        <label class="form-label">Buscar</label>
        <input name="q" value="@q" class="form-control" placeholder="Nombre / Código / Lote / Laboratorio" />
    </div>

    <div class="col-12 col-md-3 col-lg-2">
        <label class="form-label">Orden</label>
        <select name="orden" class="form-select">
            <option value="codigo" selected="@(orden == "codigo")">Código</option>
            <option value="nombre" selected="@(orden == "nombre")">Nombre</option>
            <option value="stock" selected="@(orden == "stock")">Stock</option>
            <option value="vence" selected="@(orden == "vence")">Vencimiento</option>
        </select>
    </div>

    <div class="col-12 col-md-3 col-lg-2">
        <input type="hidden" name="soloActivos" value="false" />
        <div class="form-check mt-4">
            <input class="form-check-input" type="checkbox" id="soloActivos" name="soloActivos" value="true" @(soloActivos ? "checked" : "") />
            <label class="form-check-label" for="soloActivos">Solo activos</label>
        </div>
    </div>

    <div class="col-12 col-md-6 col-lg-2 d-grid">
        <button type="submit" class="btn btn-primary">Aplicar</button>
    </div>

    <div class="col-12 col-md-6 col-lg-2 d-grid">
        <a class="btn btn-outline-secondary" asp-action="Index">Limpiar</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-bordered table-striped align-middle">
        <thead class="table-light">
            <tr>
                <th>Estado</th>
                <th>Código</th>
                <th>Nombre</th>
                <th>Lab</th>
                <th>Vence</th>
                <th>Stock</th>
                <th>Venta</th>
                <th>Receta</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Items != null && Model.Items.Any())
            {
                @foreach (var m in Model.Items)
                {
                    var vencido = m.FechaVencimiento < hoy;
                    var porVencer = !vencido && m.FechaVencimiento <= limite30;
                    var stockBajo = m.Stock <= m.StockMinimo;

                    <tr>
                        <td>
                            @if (!m.Activo)
                            {
                                <span class="badge bg-secondary">Inactivo</span>
                            }
                            else if (vencido)
                            {
                                <span class="badge bg-danger">Vencido</span>
                            }
                            else if (porVencer)
                            {
                                <span class="badge bg-warning text-dark">Por vencer</span>
                            }
                            else if (stockBajo)
                            {
                                <span class="badge bg-info text-dark">Stock bajo</span>
                            }
                            else
                            {
                                <span class="badge bg-success">OK</span>
                            }
                        </td>
                        <td>@m.Codigo</td>
                        <td>@m.Nombre</td>
                        <td>@m.Laboratorio</td>
                        <td>@m.FechaVencimiento.ToString("dd/MM/yyyy")</td>
                        <td>@m.Stock / Min: @m.StockMinimo</td>
                        <td>S/ @m.PrecioVenta.ToString("0.00")</td>
                        <td>@(m.RequiereReceta ? "Sí" : "No")</td>
                        <td class="text-center">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@m.Id">Editar</a>
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@m.Id">Ver</a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@m.Id">Desactivar</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="9" class="text-center text-muted py-4">
                        No se encontraron medicamentos con los filtros actuales.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (ViewBag.TotalPaginas > 1)
{
    <nav class="mt-4 d-flex justify-content-center">
        <ul class="pagination botica-pagination">
            <li class="page-item @(ViewBag.PaginaActual == 1 ? "disabled" : "")">
                <a class="page-link"
                       asp-action="Index"
                       asp-route-q="@ViewBag.Q"
                       asp-route-orden="@ViewBag.Orden"
                       asp-route-soloActivos="@ViewBag.SoloActivos"
                       asp-route-pagina="@(ViewBag.PaginaActual - 1)">
                    Anterior
                </a>
            </li>

            @for (int i = 1; i <= (int)ViewBag.TotalPaginas; i++)
            {
                <li class="page-item @(i == (int)ViewBag.PaginaActual ? "active" : "")">
                    <a class="page-link"
                           asp-action="Index"
                           asp-route-q="@ViewBag.Q"
                           asp-route-orden="@ViewBag.Orden"
                           asp-route-soloActivos="@ViewBag.SoloActivos"
                           asp-route-pagina="@i">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(ViewBag.PaginaActual == ViewBag.TotalPaginas ? "disabled" : "")">
                <a class="page-link"
                       asp-action="Index"
                       asp-route-q="@ViewBag.Q"
                       asp-route-orden="@ViewBag.Orden"
                       asp-route-soloActivos="@ViewBag.SoloActivos"
                       asp-route-pagina="@(ViewBag.PaginaActual + 1)">
                    Siguiente
                </a>
            </li>
        </ul>
    </nav>
}
}