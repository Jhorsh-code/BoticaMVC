@model BoticaMVC.Models.Medicamento
@{
    ViewData["Title"] = "Nuevo Medicamento";
}

<h2>Nuevo Medicamento</h2>

<form asp-action="Create" method="post" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="row g-2">
        <div class="col-md-3">
            <label asp-for="Codigo" class="form-label"></label>
            <input asp-for="Codigo" class="form-control" placeholder="MED-0001" />
            <span asp-validation-for="Codigo" class="text-danger"></span>
        </div>

        <div class="col-md-5">
            <label asp-for="Nombre" class="form-label"></label>
            <input asp-for="Nombre" class="form-control" />
            <span asp-validation-for="Nombre" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="Laboratorio" class="form-label"></label>
            <input asp-for="Laboratorio" class="form-control" />
            <span asp-validation-for="Laboratorio" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label asp-for="Presentacion" class="form-label"></label>
            <input asp-for="Presentacion" class="form-control" placeholder="Tabletas/Jarabe..." />
            <span asp-validation-for="Presentacion" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label asp-for="Lote" class="form-label"></label>
            <input asp-for="Lote" class="form-control" />
            <span asp-validation-for="Lote" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label asp-for="FechaVencimiento" class="form-label"></label>
            <input asp-for="FechaVencimiento" class="form-control" type="date" />
            <span asp-validation-for="FechaVencimiento" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label asp-for="Ubicacion" class="form-label"></label>
            <input asp-for="Ubicacion" class="form-control" placeholder="Estante A-2" />
            <span asp-validation-for="Ubicacion" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label asp-for="Stock" class="form-label"></label>
            <input asp-for="Stock" class="form-control" />
            <span asp-validation-for="Stock" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label asp-for="StockMinimo" class="form-label"></label>
            <input asp-for="StockMinimo" class="form-control" />
            <span asp-validation-for="StockMinimo" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label asp-for="PrecioCompra" class="form-label"></label>
            <input asp-for="PrecioCompra" class="form-control" />
            <span asp-validation-for="PrecioCompra" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label asp-for="PrecioVenta" class="form-label"></label>
            <input asp-for="PrecioVenta" class="form-control" />
            <span asp-validation-for="PrecioVenta" class="text-danger"></span>
        </div>

        <div class="col-md-3 d-flex align-items-center">
            <input asp-for="RequiereReceta" class="form-check-input me-2" />
            <label asp-for="RequiereReceta" class="form-check-label"></label>
        </div>

        <div class="col-md-3 d-flex align-items-center">
            <input asp-for="Activo" class="form-check-input me-2" checked />
            <label asp-for="Activo" class="form-check-label"></label>
        </div>
    </div>

    <div class="mt-3">
        <button class="btn btn-success">Guardar</button>
        <a class="btn btn-secondary" asp-action="Index">Volver</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
