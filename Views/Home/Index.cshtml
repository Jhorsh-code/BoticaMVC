@model BoticaMVC.ViewModels.DashboardVM
@{
    ViewData["Title"] = "Inicio - Botica";
}

<div class="mb-3">
    <h2 class="mb-0">Dashboard - Botica</h2>
    <p class="text-muted">Resumen del inventario (solo medicamentos activos)</p>
</div>

<div class="row g-3">
    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6 class="text-muted">Total medicamentos</h6>
                <h2 class="mb-0">@Model.TotalMedicamentos</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-warning">
            <div class="card-body">
                <h6 class="text-muted">Stock bajo</h6>
                <h2 class="mb-0">@Model.StockBajo</h2>
                <small class="text-muted">Stock ≤ Stock mínimo</small>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-danger">
            <div class="card-body">
                <h6 class="text-muted">Vencidos</h6>
                <h2 class="mb-0">@Model.Vencidos</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-info">
            <div class="card-body">
                <h6 class="text-muted">Por vencer (30 días)</h6>
                <h2 class="mb-0">@Model.PorVencer30Dias</h2>
            </div>
        </div>
    </div>
</div>

<hr class="my-4" />

<div class="d-flex gap-2">
    <a class="btn btn-primary" asp-controller="Medicamentos" asp-action="Index">Ir a Medicamentos</a>
    <a class="btn btn-outline-dark" asp-controller="Medicamentos" asp-action="Reporte">Reporte (Imprimir)</a>
    <a class="btn btn-outline-success" asp-controller="Medicamentos" asp-action="ReporteExcel">Reporte (Excel)</a>
</div>
