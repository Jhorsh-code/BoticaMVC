<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BoticaMVC</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="app-body">
    <header>
        <nav class="navbar navbar-expand-lg app-navbar shadow-sm">
            <div class="container">
                <a class="navbar-brand app-brand" asp-controller="Home" asp-action="Index">BoticaMVC</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu"
                        aria-controls="menu" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="menu">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 app-nav-links">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Dashboard</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Medicamentos" asp-action="Index">Medicamentos</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Ventas" asp-action="Index">POS</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Ventas" asp-action="Historial">Historial Ventas</a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Reportes
                            </a>
                            <ul class="dropdown-menu shadow-sm">
                                <li>
                                    <a class="dropdown-item" asp-controller="Medicamentos" asp-action="Reporte">
                                        Reporte (Imprimir)
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Medicamentos" asp-action="ReporteExcel">
                                        Reporte (Excel)
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Medicamentos" asp-action="ReportePdf">
                                        Reporte (PDF)
                                    </a>
                                </li>
                            </ul>
                        </li>
                    </ul>

                    <span class="navbar-text app-navbar-text">
                        Inventario de Botica
                    </span>
                </div>
            </div>
        </nav>
    </header>

    <div class="container app-content">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer">
        <div class="container d-flex justify-content-between flex-wrap gap-2 py-3">
            <span>BoticaMVC</span>
            <span>&copy; @DateTime.Now.Year Todos los derechos reservados</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>